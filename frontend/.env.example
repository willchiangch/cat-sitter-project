# Vite environment variables must be prefixed with VITE_ to be exposed to the client
# VITE_RESEND_API_KEY=... (Not recommended for frontend)

# UAT/Security: 是否啟用 Email/密碼 登入與註冊 (主要用於 UAT 環境隱藏以強制使用社群登入)
VITE_ENABLE_PASSWORD_LOGIN=true

# GCP Cloud Run Proxy Settings (Used for local E2E testing against Cloud Run)
GCP_PROJECT_ID=your-project-id-here
GCP_REGION=asia-east1
GCP_SERVICE_NAME=whiskerwatch-api
