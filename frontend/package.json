{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "cloud-run:proxy": "source .env && ${GCLOUD_BIN_PATH:-gcloud} run services proxy $GCP_SERVICE_NAME --region $GCP_REGION --project $GCP_PROJECT_ID --port 8081",
    "test:e2e:cloud": "concurrently -k -s first \"npm run cloud-run:proxy\" \"wait-on http://localhost:8081/v3/api-docs && playwright test --config=playwright.cloud.config.ts\"",
    "api:fetch": "curl -sf http://localhost:8080/v3/api-docs -o ../backend/openapi.json",
    "api:generate": "openapi-ts",
    "api:sync": "npm run api:fetch && npm run api:generate",
    "screenshot": "playwright test --config=playwright.screenshot.config.ts && node scripts/generate-ui-report.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "axios": "^1.14.0",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^1.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.1",
    "react-router-dom": "^7.13.2",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@hey-api/client-axios": "^0.7.0",
    "@hey-api/openapi-ts": "^0.73.0",
    "@playwright/browser-chromium": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^9.0.4"
  }
}
